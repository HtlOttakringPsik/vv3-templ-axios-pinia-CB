{
  "$schema": "https://biomejs.dev/schemas/2.3.14/schema.json",
  "files": { "ignoreUnknown": false },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": { "noConsole": "off", "noAlert": "error" }
    }
  },
  "javascript": { "formatter": { "quoteStyle": "single" } },
  "assist": {
    "enabled": true,
    "actions": { "source": { "organizeImports": "on" } }
  }
}
